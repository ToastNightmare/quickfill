# QuickFill Environment Variables
# Copy this file to .env.local and fill in your values.

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Public app URLs
NEXT_PUBLIC_APP_URL=https://getquickfill.com
NEXT_PUBLIC_APP_DOMAIN=getquickfill.com

# Database: Neon Postgres
DATABASE_URL=postgresql://...

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Pro Monthly recurring price for the current A$2 intro offer (A$25/month after trial)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# Pro Monthly one-time intro price charged at checkout (A$2)
STRIPE_PRO_MONTHLY_INTRO_PRICE_ID=price_...
# Pro Monthly rollback recurring price for the old coupon path
STRIPE_PRO_PRICE_ID=price_...
# Pro Annual recurring price (A$149/year)
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
# Rollback coupon for the old Pro Monthly path only
STRIPE_PRO_INTRO_COUPON_ID=...
STRIPE_BUSINESS_PRICE_ID=price_...
STRIPE_BUSINESS_ANNUAL_PRICE_ID=price_...

# Admin and QA
ADMIN_EMAILS=owner@example.com
QUICKFILL_ADMIN_EMAILS=owner@example.com
QUICKFILL_QA_TOKEN=

# OpenAI AI field detection
OPENAI_API_KEY=sk-...

# Australian Business Register ABN lookup
ABR_GUID=00000000-0000-0000-0000-000000000000

# Google Ads
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-18234250879
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=jzjNCNyf970cEP-s4vzD
